# ── Infrastructure (REQUIRED) ────────────────────────
DATABASE_URL=postgresql+asyncpg://autoswarm:autoswarm@localhost:5432/autoswarm  # REQUIRED
# OPTIONAL — Database pool tuning (defaults are usually fine)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_RECYCLE=1800
# DB_POOL_TIMEOUT=30
REDIS_URL=redis://localhost:6379  # REQUIRED
ENVIRONMENT=development  # OPTIONAL (default: production)

# ── Security ───────────────────────────────────────
DEV_AUTH_BYPASS=true  # OPTIONAL (default: false; only enable in development)
RATE_LIMIT_PER_MINUTE=60  # OPTIONAL (default: 60)

# ── Auth (Janua OIDC) ──────────────────────────────
JANUA_ISSUER_URL=  # Set to your Janua instance URL (e.g., https://auth.example.com)
JANUA_CLIENT_ID=autoswarm-office  # OPTIONAL (default: autoswarm-office)
JANUA_CLIENT_SECRET=  # OPTIONAL (required for production auth)
JANUA_JWT_SECRET=  # OPTIONAL (required for production auth)
NEXT_PUBLIC_JANUA_ISSUER_URL=  # Set to same as JANUA_ISSUER_URL
NEXT_PUBLIC_JANUA_CLIENT_ID=autoswarm-office  # OPTIONAL (frontend)

# ── Billing (Dhanam) ───────────────────────────────
DHANAM_API_URL=  # Set to your Dhanam instance URL
DHANAM_WEBHOOK_SECRET=  # OPTIONAL (required for billing webhooks)
NEXT_PUBLIC_DHANAM_URL=  # Set to same as DHANAM_API_URL

# ── Workers ────────────────────────────────────────
# Workers use DATABASE_URL directly (same DB as nexus-api)
WORKER_API_TOKEN=dev-bypass  # OPTIONAL (default: dev-bypass; set to real JWT in production)
APPROVAL_TIMEOUT=300  # OPTIONAL (default: 300 seconds)

# ── Phyne-CRM Integration ──────────────────────────
PHYNE_CRM_URL=http://localhost:3000  # OPTIONAL (required for CRM graph)
PHYNE_CRM_TOKEN=  # OPTIONAL (required for CRM graph)

# ── AI Inference (OPTIONAL — at least one needed for LLM inference) ──
ANTHROPIC_API_KEY=  # OPTIONAL (enables Anthropic models)
OPENAI_API_KEY=  # OPTIONAL (enables OpenAI models)
OPENROUTER_API_KEY=  # OPTIONAL (enables OpenRouter models)
TOGETHER_API_KEY=  # OPTIONAL (enables Together AI models)
FIREWORKS_API_KEY=  # OPTIONAL (enables Fireworks AI models)
DEEPINFRA_API_KEY=  # OPTIONAL (enables DeepInfra models)
SILICONFLOW_API_KEY=  # OPTIONAL (enables SiliconFlow GLM-5)
MOONSHOT_API_KEY=  # OPTIONAL (enables Moonshot Kimi K2.5)
GROQ_API_KEY=  # OPTIONAL (enables Groq models)
MISTRAL_API_KEY=  # OPTIONAL (enables Mistral models)
OLLAMA_BASE_URL=http://localhost:11434  # OPTIONAL (default: http://localhost:11434)
ORG_CONFIG_PATH=~/.autoswarm/org-config.yaml  # OPTIONAL (org-level routing config)

# ── Search ─────────────────────────────────────────
SEARCH_API_KEY=  # OPTIONAL (required for research graph web search)
SEARCH_PROVIDER=tavily  # OPTIONAL (default: tavily)
REPO_BASE_PATH=~/.autoswarm/repos  # OPTIONAL (default: ~/.autoswarm/repos)

# ── GitHub / Deployment ───────────────────────────
GITHUB_TOKEN=  # OPTIONAL (required for git push and PR creation)
GITHUB_REPOS=  # OPTIONAL (gateway polling)
GITHUB_WEBHOOK_SECRET=  # OPTIONAL (required for GitHub webhook verification)
ENCLII_WEBHOOK_SECRET=  # OPTIONAL (required for Enclii webhook verification)
ENCLII_API_URL=  # OPTIONAL (required for deployment graph)
ENCLII_DEPLOY_TOKEN=  # OPTIONAL (required for deployment graph)

# ── OpenClaw Gateway ───────────────────────────────
OPENCLAW_API_KEY=  # OPTIONAL
OPENCLAW_MEMORY_DIR=./data/memory  # OPTIONAL
GATEWAY_PORT=4304  # OPTIONAL (default: 4304)

# ── Colyseus ────────────────────────────────────────
COLYSEUS_SECRET=change-me-in-production  # OPTIONAL (change in production!)
COLYSEUS_SERVICE_TOKEN=  # OPTIONAL

# ── WebRTC TURN Server (optional, required for corporate NAT traversal) ──
NEXT_PUBLIC_TURN_URL=turn:localhost:3478
NEXT_PUBLIC_TURN_USERNAME=autoswarm
NEXT_PUBLIC_TURN_CREDENTIAL=autoswarm123

# ── Ports ───────────────────────────────────────────
NEXUS_API_PORT=4300  # OPTIONAL (default: 4300)
OFFICE_UI_PORT=4301  # OPTIONAL (default: 4301)
ADMIN_PORT=4302  # OPTIONAL (default: 4302)
COLYSEUS_PORT=4303  # OPTIONAL (default: 4303)

# ── Frontend ───────────────────────────────────────
NEXT_PUBLIC_GITHUB_REPOS=  # OPTIONAL
NEXT_PUBLIC_APP_URL=https://agents-app.madfam.io  # OPTIONAL (landing page links)
NEXT_PUBLIC_API_URL=http://localhost:4300  # OPTIONAL (default: http://localhost:4300)
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:4303  # OPTIONAL (default: ws://localhost:4303)
NEXT_PUBLIC_APPROVALS_WS_URL=ws://localhost:4300/api/v1/approvals/ws  # OPTIONAL
NEXT_PUBLIC_EVENTS_WS_URL=ws://localhost:4300/api/v1/events/ws  # OPTIONAL

# ── Guest Access ──────────────────────────────────
NEXT_PUBLIC_GUEST_ACCESS_ENABLED=true  # OPTIONAL (default: true; set false to disable guest join)
# NEXT_PUBLIC_GUEST_DEFAULT_ORG=  # OPTIONAL (org_id for invite-less guest joins)

# ── Demo Mode ────────────────────────────────────
NEXT_PUBLIC_DEMO_ENABLED=true  # OPTIONAL (default: true; set false to hide "Try Demo" CTA)

# ── CSP / Security Headers ───────────────────────
# CSP_EXTRA_SOURCES=  # OPTIONAL (extra connect-src origins, space-separated)

# ── OpenTelemetry ─────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317  # OPTIONAL (enables OTel tracing)

# ── Skills ────────────────────────────────────────
AUTOSWARM_COMMUNITY_SKILLS_ENABLED=false  # OPTIONAL (default: false)

# ── Private npm Registry ──────────────────────────
NPM_REGISTRY_TOKEN=  # OPTIONAL (required for private npm registry)
