# ── Infrastructure ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autoswarm:autoswarm@localhost:5432/autoswarm
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development

# ── Security ───────────────────────────────────────
DEV_AUTH_BYPASS=false
RATE_LIMIT_PER_MINUTE=60

# ── Auth (Janua OIDC) ──────────────────────────────
JANUA_ISSUER_URL=https://auth.madfam.io
JANUA_CLIENT_ID=autoswarm-office
JANUA_CLIENT_SECRET=
JANUA_JWT_SECRET=
NEXT_PUBLIC_JANUA_ISSUER_URL=https://auth.madfam.io
NEXT_PUBLIC_JANUA_CLIENT_ID=autoswarm-office

# ── Billing (Dhanam) ───────────────────────────────
DHANAM_API_URL=https://api.dhan.am
DHANAM_WEBHOOK_SECRET=
NEXT_PUBLIC_DHANAM_URL=https://api.dhan.am

# ── Workers ────────────────────────────────────────
WORKER_DATABASE_URL=

# ── Phyne-CRM Integration ──────────────────────────
PHYNE_CRM_URL=http://localhost:3000
PHYNE_CRM_TOKEN=

# ── AI Inference ────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ── Search ─────────────────────────────────────────
SEARCH_API_KEY=
SEARCH_PROVIDER=tavily
REPO_BASE_PATH=/tmp/autoswarm-repos

# ── OpenClaw Gateway ───────────────────────────────
OPENCLAW_API_KEY=
OPENCLAW_MEMORY_DIR=./data/memory
GATEWAY_PORT=4304
GITHUB_TOKEN=
GITHUB_REPOS=

# ── Colyseus ────────────────────────────────────────
COLYSEUS_SECRET=change-me-in-production

# ── WebRTC TURN Server (optional, required for corporate NAT traversal) ──
# NEXT_PUBLIC_TURN_URL=turn:your-turn-server.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=
# NEXT_PUBLIC_TURN_CREDENTIAL=

# ── Ports ───────────────────────────────────────────
NEXUS_API_PORT=4300
OFFICE_UI_PORT=4301
ADMIN_PORT=4302
COLYSEUS_PORT=4303

# ── Frontend ───────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4300
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:4303
NEXT_PUBLIC_APPROVALS_WS_URL=ws://localhost:4300/api/v1/approvals/ws

# ── Skills ────────────────────────────────────────
AUTOSWARM_COMMUNITY_SKILLS_ENABLED=false

# ── MADFAM Registry ────────────────────────────────
NPM_MADFAM_TOKEN=
