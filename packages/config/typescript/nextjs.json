{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Selva Next.js TypeScript Config",
  "extends": "./base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "jsx": "preserve"
  }
}
