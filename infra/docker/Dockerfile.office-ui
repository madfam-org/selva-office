# Stage 1: Dependencies
FROM node:20-alpine AS deps

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/office-ui/package.json apps/office-ui/
COPY packages/ packages/

RUN pnpm install --frozen-lockfile

# Stage 2: Builder
FROM node:20-alpine AS builder

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@latest --activate

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/office-ui/node_modules ./apps/office-ui/node_modules
COPY --from=deps /app/packages/ ./packages/
COPY apps/office-ui/ apps/office-ui/
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json turbo.json ./

ENV NEXT_TELEMETRY_DISABLED=1

# Next.js bakes NEXT_PUBLIC_* at build time — these must be ARGs
ARG NEXT_PUBLIC_API_URL=https://api.selva.town
ARG NEXT_PUBLIC_COLYSEUS_URL=wss://ws.selva.town
ARG NEXT_PUBLIC_JANUA_ISSUER_URL=https://auth.selva.town
ARG NEXT_PUBLIC_JANUA_CLIENT_ID=autoswarm-office
ARG NEXT_PUBLIC_DEMO_ENABLED=true
ARG NEXT_PUBLIC_GUEST_ACCESS_ENABLED=true

ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_COLYSEUS_URL=$NEXT_PUBLIC_COLYSEUS_URL
ENV NEXT_PUBLIC_JANUA_ISSUER_URL=$NEXT_PUBLIC_JANUA_ISSUER_URL
ENV NEXT_PUBLIC_JANUA_CLIENT_ID=$NEXT_PUBLIC_JANUA_CLIENT_ID
ENV NEXT_PUBLIC_DEMO_ENABLED=$NEXT_PUBLIC_DEMO_ENABLED
ENV NEXT_PUBLIC_GUEST_ACCESS_ENABLED=$NEXT_PUBLIC_GUEST_ACCESS_ENABLED

RUN pnpm --filter @autoswarm/shared-types build && \
    pnpm --filter office-ui build

# Stage 3: Runner
FROM node:20-alpine AS runner

WORKDIR /app

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

LABEL org.opencontainers.image.source=https://github.com/madfam-org/autoswarm-office

COPY --from=builder --chown=nextjs:nodejs /app/apps/office-ui/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/office-ui/.next/static ./apps/office-ui/.next/static
COPY --from=builder /app/apps/office-ui/public ./apps/office-ui/public

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

USER nextjs

CMD ["node", "apps/office-ui/server.js"]
