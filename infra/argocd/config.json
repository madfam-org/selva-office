{
  "project": "autoswarm-office",
  "repoURL": "https://github.com/your-org/autoswarm-office",
  "targetRevision": "main",
  "path": "infra/k8s/production",
  "destination": {
    "server": "https://kubernetes.default.svc",
    "namespace": "autoswarm"
  },
  "syncPolicy": {
    "automated": {
      "prune": true,
      "selfHeal": true
    }
  }
}
