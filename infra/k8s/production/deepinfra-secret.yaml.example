# ═══════════════════════════════════════════════════════════════════════
# DeepInfra API key secret — TEMPLATE ONLY
# ═══════════════════════════════════════════════════════════════════════
# DO NOT commit a filled version of this file. Apply it via the enclii
# CLI or kubectl with the key sourced from a password manager or Vault.
#
#   enclii secrets set DEEPINFRA_API_KEY=<your-key> --service nexus-api --secret
#   enclii secrets set DEEPINFRA_API_KEY=<your-key> --service autoswarm-workers --secret
#
# If you must apply directly:
#
#   kubectl create secret generic autoswarm-deepinfra \
#     --namespace autoswarm \
#     --from-literal=DEEPINFRA_API_KEY="<key-from-deepinfra.com>" \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# Then patch nexus-api and autoswarm-workers deployments to reference it:
#
#   env:
#     - name: DEEPINFRA_API_KEY
#       valueFrom:
#         secretKeyRef:
#           name: autoswarm-deepinfra
#           key: DEEPINFRA_API_KEY
#
# Obtain the key from https://deepinfra.com/dash/api_keys after logging in
# with GitHub OAuth as innovacionesmadfam@proton.me (madfam-io org access).
# ═══════════════════════════════════════════════════════════════════════

apiVersion: v1
kind: Secret
metadata:
  name: autoswarm-deepinfra
  namespace: autoswarm
  labels:
    app.kubernetes.io/name: deepinfra-secret
    app.kubernetes.io/part-of: autoswarm-office
type: Opaque
stringData:
  DEEPINFRA_API_KEY: "REPLACE_ME_WITH_KEY_FROM_DEEPINFRA_DOT_COM"
